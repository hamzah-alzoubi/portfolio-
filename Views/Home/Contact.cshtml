@model portfoilo.Models.Message
@using portfoilo.Models

@{
    ViewData["Title"] = "Contact";
}

<style>
    .contact-hero {
        background: #1A2E44;
        padding: 90px 0 70px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .contact-hero::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            background: #2A9D8F;
            border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
            opacity: 0.08;
            top: -120px;
            right: -100px;
        }

        .contact-hero::after {
            content: '';
            position: absolute;
            width: 350px;
            height: 350px;
            background: #2A9D8F;
            border-radius: 40% 60% 30% 70% / 60% 40% 60% 40%;
            opacity: 0.06;
            bottom: -80px;
            left: -80px;
        }

        .contact-hero h1 {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 800;
            color: #F2EDE4;
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

            .contact-hero h1 span {
                color: #2A9D8F;
            }

        .contact-hero p {
            font-family: 'DM Sans', sans-serif;
            color: rgba(242,237,228,0.7);
            font-size: 1.1rem;
            max-width: 500px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

    /* ── Section ── */
    .contact-section {
        background: #F2EDE4;
        padding: 80px 0;
    }

    .contact-wrapper {
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 60px;
        align-items: start;
        max-width: 900px;
        margin: 0 auto;
    }

    /* ── Left info ── */
    .contact-info h2 {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        color: #1A2E44;
        margin-bottom: 14px;
    }

    .contact-info p {
        font-family: 'DM Sans', sans-serif;
        color: #666;
        font-size: 0.97rem;
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .contact-item {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
    }

    .contact-icon {
        width: 42px;
        height: 42px;
        background: #1A2E44;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: #2A9D8F;
    }

    .contact-item-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.92rem;
        color: #444;
    }

        .contact-item-text strong {
            display: block;
            color: #1A2E44;
            font-weight: 600;
            margin-bottom: 2px;
        }

    /* ── Form card ── */
    .contact-form-card {
        background: #fff;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 4px 24px rgba(26,46,68,0.08);
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.88rem;
            font-weight: 600;
            color: #1A2E44;
            margin-bottom: 7px;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            background: #F8F6F2;
            border: 1.5px solid #e8e3da;
            border-radius: 10px;
            padding: 12px 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            color: #1A2E44;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .form-group input:focus,
            .form-group textarea:focus {
                border-color: #2A9D8F;
                box-shadow: 0 0 0 3px rgba(42,157,143,0.12);
            }

        .form-group textarea {
            resize: vertical;
            min-height: 140px;
        }

    .char-counter {
        text-align: right;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        color: #999;
        margin-top: 5px;
        transition: color 0.2s;
    }

        .char-counter.warning {
            color: #e67e22;
        }

        .char-counter.danger {
            color: #e74c3c;
        }

    .btn-send {
        width: 100%;
        background: #2A9D8F;
        color: #fff;
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        padding: 14px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-send:hover {
            background: #238a7d;
            transform: translateY(-2px);
        }

    /* validation */
    .field-validation-error {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        color: #e74c3c;
        margin-top: 5px;
        display: block;
    }

    .input-validation-error {
        border-color: #e74c3c !important;
    }

    /* success toast */
    .success-toast {
        background: #2A9D8F;
        color: #fff;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        padding: 14px 24px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    @@media (max-width: 768px) {
        .contact-wrapper {
            grid-template-columns: 1fr;
            gap: 40px;
        }
    }
</style>

<!-- Hero -->
<section class="contact-hero">
    <div class="container">
        <h1>Get In <span>Touch</span></h1>
        <p>Have a question or want to work together? Drop me a message.</p>
    </div>
</section>

<!-- Contact Section -->
<section class="contact-section">
    <div class="container">
        <div class="contact-wrapper">

            <!-- Left: Info -->
            <div class="contact-info">
                <h2>Let's talk</h2>
                <p>I'm currently open to new opportunities and always happy to connect. Fill out the form and I'll get back to you as soon as possible.</p>

                <div class="contact-item">
                    <div class="contact-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </div>
                    <div class="contact-item-text">
                        <strong>Email</strong>
                        itshamzah99@gmail.com
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                    </div>
                    <div class="contact-item-text">
                        <strong>Location</strong>
                        Amman, Jordan
                    </div>
                </div>
            </div>

            <!-- Right: Form -->
            <div class="contact-form-card">

                @if (TempData["Success"] != null)
                {
                    <div class="success-toast">
                        ✅ @TempData["Success"]
                    </div>
                }

                <form asp-action="Contact" asp-controller="Home" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="SenderName">Your Name</label>
                        <input asp-for="SenderName" placeholder="Hamzah" />
                        <span asp-validation-for="SenderName" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EmailAddress">Your Email</label>
                        <input asp-for="EmailAddress" type="email" placeholder="hello@example.com" />
                        <span asp-validation-for="EmailAddress" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Body">Message</label>
                        <textarea asp-for="Body" id="messageBody" placeholder="Write your message here..." maxlength="500"></textarea>
                        <div class="char-counter" id="charCounter">0 / 500</div>
                        <span asp-validation-for="Body" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="btn-send">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                        Send Message
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

<script>
    const textarea = document.getElementById('messageBody');
    const counter = document.getElementById('charCounter');

    textarea.addEventListener('input', () => {
        const len = textarea.value.length;
        counter.textContent = `${len} / 500`;
        counter.classList.remove('warning', 'danger');
        if (len >= 450) counter.classList.add('danger');
        else if (len >= 350) counter.classList.add('warning');
    });
</script>