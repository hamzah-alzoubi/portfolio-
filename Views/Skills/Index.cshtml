@model IEnumerable<portfoilo.Models.Skills>

@{
    Layout = "adminLayout";
    ViewData["Title"] = "Skills";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Skills</h1>
    <a asp-action="Create" class="btn btn-teal">
        <i class="bi bi-plus-lg me-1"></i> Add Skill
    </a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Category)</th>
            <th>@Html.DisplayNameFor(model => model.Level)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <div style="flex:1;height:6px;background:#e8e2d8;border-radius:99px;max-width:120px;">
                            <div style="width:@(item.Level)%;height:100%;background:var(--teal);border-radius:99px;"></div>
                        </div>
                        <span style="font-size:0.85rem;color:#7a8fa8;">@item.Level%</span>
                    </div>
                </td>
                <td class="table-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-teal">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-navy">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
