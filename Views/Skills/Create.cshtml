@model portfoilo.Models.Skills

@{
    Layout = "adminLayout";
    ViewData["Title"] = "Create Skill";
}

<h1 class="mb-4">Add New Skill</h1>

<div class="admin-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Category" class="form-label"></label>
            <select asp-for="Category" class="form-select"
                    asp-items="Html.GetEnumSelectList<portfoilo.Models.SkillsCategory>()"></select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Level" class="form-label"></label>
            <input asp-for="Level" class="form-control" type="number" min="0" max="100" />
            <span asp-validation-for="Level" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit" value="Create Skill" class="btn btn-teal" />
            <a asp-action="Index" class="btn btn-navy">Back to List</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
