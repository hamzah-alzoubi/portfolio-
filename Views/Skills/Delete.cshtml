@model portfoilo.Models.Skills

@{
    Layout = "adminLayout";
    ViewData["Title"] = "Delete Skill";
}

<h1 class="mb-4">Delete Skill</h1>

<div class="admin-card" style="max-width: 500px;">
    <p class="text-danger fw-semibold mb-3">Are you sure you want to delete this skill? This cannot be undone.</p>

    <dl class="row mb-4">
        <dt class="col-sm-4">Name</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-4">Category</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Category)</dd>

        <dt class="col-sm-4">Level</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Level) / 100</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <input type="submit" value="Yes, Delete" class="btn btn-outline-danger" />
            <a asp-action="Index" class="btn btn-navy">Cancel</a>
        </div>
    </form>
</div>
