@model portfoilo.Models.Projects

@{
    Layout = "adminLayout";
    ViewData["Title"] = "Edit Project";
}

<h1 class="mb-4">Edit Project</h1>

<div class="admin-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TechUsed" class="form-label"></label>
            <input asp-for="TechUsed" class="form-control" placeholder="e.g. Flutter, .NET, SQL Server" />
            <span asp-validation-for="TechUsed" class="text-danger"></span>
            <div class="form-text">Separate multiple technologies with commas.</div>
        </div>

        <div class="mb-3">
            <label asp-for="GitHubLink" class="form-label"></label>
            <input asp-for="GitHubLink" class="form-control" placeholder="https://github.com/..." />
            <span asp-validation-for="GitHubLink" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="LiveDemoLink" class="form-label"></label>
            <input asp-for="LiveDemoLink" class="form-control" placeholder="https://..." />
            <span asp-validation-for="LiveDemoLink" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit" value="Save Changes" class="btn btn-teal" />
            <a asp-action="Index" class="btn btn-navy">Back to List</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
