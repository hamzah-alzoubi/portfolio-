@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password — Hamzah</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --cream: #F2EDE4;
            --teal: #2A9D8F;
            --teal-dark: #21867a;
            --navy: #1A2E44;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

            body::before {
                content: '';
                position: absolute;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(42,157,143,0.08) 0%, transparent 70%);
                bottom: -100px;
                left: -100px;
                pointer-events: none;
            }

        .card {
            background: #fff;
            border-radius: 24px;
            padding: 3rem;
            max-width: 440px;
            width: 90%;
            box-shadow: 0 8px 40px rgba(26,46,68,0.1);
            position: relative;
            z-index: 1;
            animation: fadeUp 0.5s ease both;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .icon {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            background: rgba(42,157,143,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.75rem;
            color: var(--navy);
            margin-bottom: 0.5rem;
        }

        .subtitle {
            color: #7a8fa8;
            font-size: 0.92rem;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .field {
            margin-bottom: 1.1rem;
        }

            .field label {
                display: block;
                font-family: 'Syne', sans-serif;
                font-weight: 600;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.07em;
                color: var(--navy);
                margin-bottom: 0.4rem;
            }

            .field input {
                width: 100%;
                padding: 0.75rem 1rem;
                border: 2px solid #e8e2d8;
                border-radius: 12px;
                font-family: 'DM Sans', sans-serif;
                font-size: 0.95rem;
                background: var(--cream);
                color: var(--navy);
                transition: border-color 0.2s, box-shadow 0.2s;
                outline: none;
            }

                .field input:focus {
                    border-color: var(--teal);
                    box-shadow: 0 0 0 3px rgba(42,157,143,0.15);
                    background: #fff;
                }

        .field-error {
            color: #e05a5a;
            font-size: 0.8rem;
            margin-top: 0.3rem;
        }

        .validation-summary {
            background: #fef0f0;
            border: 1px solid #f5c6c6;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            margin-bottom: 1.25rem;
            font-size: 0.85rem;
            color: #c0392b;
        }

        .btn-submit {
            width: 100%;
            padding: 0.85rem;
            background: var(--teal);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: background 0.2s, transform 0.15s;
        }

            .btn-submit:hover {
                background: var(--teal-dark);
                transform: translateY(-1px);
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🔒</div>
        <h1>Reset password</h1>
        <p class="subtitle">Choose a strong new password for your account.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="field">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" autocomplete="username" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Password">New Password</label>
                <input asp-for="Input.Password" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>

            <input asp-for="Input.Code" type="hidden" />

            <button type="submit" class="btn-submit">Reset Password →</button>
        </form>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
